<Project Sdk="Microsoft.NET.Sdk">

  <!--
    tamp-gitversion's self-hosted build script. Uses Tamp itself —
    PackageReferences (not sibling-clone ProjectReferences) so this is
    end-to-end dogfooding of published Tamp.Core / Tamp.NetCli.V10.

    Single-target net10 (the build script just runs on whichever
    .NET 10 SDK CI brings up). IsPackable=false; never published.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Tamp.GitVersion.Build</RootNamespace>
    <AssemblyName>Tamp.GitVersion.Build</AssemblyName>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Tamp.Core" />
    <PackageReference Include="Tamp.NetCli.V10" />
    <PackageReference Include="Tamp.Telegram" />
    <PackageReference Include="Tamp.SonarScanner.V10" />
  </ItemGroup>

</Project>
